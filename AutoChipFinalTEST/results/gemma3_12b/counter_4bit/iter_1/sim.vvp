    %set/v v0134A118_0, 8, 32;
T_5.4 ;
    %load/v 8, v0134A118_0, 32;
   %cmpi/s 8, 16, 32;
    %or 5, 4, 1;
    %jmp/0xz T_5.5, 5;
    %wait E_01347F70;
    %load/v 8, v0134A6B8_0, 4;
    %mov 12, 0, 28;
    %load/v 40, v0134A118_0, 32;
    %movi 72, 16, 32;
    %mod 40, 72, 32;
    %cmp/u 8, 40, 32;
    %inv 6, 1;
    %jmp/0xz  T_5.6, 6;
    %load/v 8, v0134A118_0, 32;
    %movi 40, 16, 32;
    %mod/s 8, 40, 32;
    %vpi_call 2 31 "$display", "FAIL: expected count=%0d got %0d (cycle %0d)", T<8,32,s>, v0134A6B8_0, v0134A118_0;
