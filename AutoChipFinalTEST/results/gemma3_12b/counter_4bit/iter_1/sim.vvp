T_3 ;
    %set/v v0134A710_0, 0, 32;
    %end;
    .thread T_3;
    .scope S_01348F08;
T_4 ;
    %delay 5000, 0;
    %load/v 8, v0134A410_0, 1;
    %inv 8, 1;
    %set/v v0134A410_0, 8, 1;
    %jmp T_4;
    .thread T_4;
    .scope S_01348F08;
T_5 ;
    %set/v v0134A170_0, 1, 1;
    %wait E_01347F70;
    %load/v 8, v0134A6B8_0, 4;
    %cmpi/u 8, 0, 4;
    %inv 6, 1;
    %jmp/0xz  T_5.0, 6;
    %vpi_call 2 17 "$display", "FAIL: after reset, count=%0d (expected 0)", v0134A6B8_0;
    %load/v 8, v0134A710_0, 32;
    %mov 40, 39, 1;
    %addi 8, 1, 33;
    %set/v v0134A710_0, 8, 32;
T_5.0 ;
    %wait E_01347F70;
    %load/v 8, v0134A6B8_0, 4;
    %cmpi/u 8, 0, 4;
    %inv 6, 1;
    %jmp/0xz  T_5.2, 6;
    %vpi_call 2 21 "$display", "FAIL: count changed while rst=1 (got %0d)", v0134A6B8_0;
    %load/v 8, v0134A710_0, 32;
    %mov 40, 39, 1;
    %addi 8, 1, 33;
