S_0x5555559f9700 .scope module, "counter_4bit_tb" "counter_4bit_tb" 2 1;
 .timescale 0 0;
v0x5555559ea2a0_0 .var "clk", 0 0;
v0x555555a15d90_0 .net "count", 3 0, v0x5555559e7740_0;  1 drivers
v0x555555a15e30_0 .var/i "fail", 31 0;
v0x555555a15ed0_0 .var/i "i", 31 0;
v0x555555a15fb0_0 .var "rst", 0 0;
E_0x5555559c0890 .event posedge, v0x5555559e6650_0;
S_0x5555559f98b0 .scope module, "uut" "counter_4bit" 2 7, 3 1 0, S_0x5555559f9700;
 .timescale 0 0;
    .port_info 0 /INPUT 1 "clk";
    .port_info 1 /INPUT 1 "rst";
    .port_info 2 /OUTPUT 4 "count";
v0x5555559e6650_0 .net "clk", 0 0, v0x5555559ea2a0_0;  1 drivers
v0x5555559e7740_0 .var "count", 3 0;
v0x5555559e9fc0_0 .net "rst", 0 0, v0x555555a15fb0_0;  1 drivers
E_0x5555559c04c0 .event posedge, v0x5555559e9fc0_0, v0x5555559e6650_0;
    .scope S_0x5555559f98b0;
T_0 ;
    %wait E_0x5555559c04c0;
    %load/vec4 v0x5555559e9fc0_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_0.0, 8;
    %pushi/vec4 0, 0, 4;
    %assign/vec4 v0x5555559e7740_0, 0;
    %jmp T_0.1;
T_0.0 ;
    %load/vec4 v0x5555559e7740_0;
    %addi 1, 0, 4;
    %assign/vec4 v0x5555559e7740_0, 0;
T_0.1 ;
    %jmp T_0;
    .thread T_0;
    .scope S_0x5555559f9700;
T_1 ;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x555555a15e30_0, 0, 32;
    %end;
    .thread T_1;
    .scope S_0x5555559f9700;
T_2 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5555559ea2a0_0, 0, 1;
    %end;
    .thread T_2;
    .scope S_0x5555559f9700;
T_3 ;
    %delay 5, 0;
    %load/vec4 v0x5555559ea2a0_0;
    %inv;
    %store/vec4 v0x5555559ea2a0_0, 0, 1;
    %jmp T_3;
    .thread T_3;
    .scope S_0x5555559f9700;
T_4 ;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x555555a15fb0_0, 0, 1;
    %wait E_0x5555559c0890;
    %delay 1, 0;
    %load/vec4 v0x555555a15d90_0;
    %cmpi/ne 0, 0, 4;
    %jmp/0xz  T_4.0, 6;
    %vpi_call 2 17 "$display", "FAIL: reset did not zero count. got %0d", v0x555555a15d90_0 {0 0 0};
    %load/vec4 v0x555555a15e30_0;
    %addi 1, 0, 32;
    %store/vec4 v0x555555a15e30_0, 0, 32;
    %jmp T_4.1;
T_4.0 ;
    %vpi_call 2 19 "$display", "PASS reset" {0 0 0};
T_4.1 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x555555a15fb0_0, 0, 1;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x555555a15ed0_0, 0, 32;
T_4.2 ; Top of for-loop
    %load/vec4 v0x555555a15ed0_0;
    %cmpi/s 16, 0, 32;
	  %jmp/0xz T_4.3, 5;
    %wait E_0x5555559c0890;
    %delay 1, 0;
    %load/vec4 v0x555555a15d90_0;
    %pad/u 32;
    %load/vec4 v0x555555a15ed0_0;
    %addi 1, 0, 32;
    %cmp/ne;
    %flag_get/vec4 6;
    %jmp/0 T_4.7, 6;
    %load/vec4 v0x555555a15ed0_0;
    %cmpi/e 15, 0, 32;
    %flag_get/vec4 4;
    %jmp/0 T_4.8, 4;
    %load/vec4 v0x555555a15d90_0;
    %pad/u 32;
    %pushi/vec4 0, 0, 32;
    %cmp/e;
    %flag_get/vec4 4;
    %and;
T_4.8;
    %nor/r;
    %and;
T_4.7;
    %flag_set/vec4 8;
    %jmp/0xz  T_4.5, 8;
    %load/vec4 v0x555555a15ed0_0;
    %cmpi/e 15, 0, 32;
    %jmp/0xz  T_4.9, 4;
    %load/vec4 v0x555555a15d90_0;
    %cmpi/ne 0, 0, 4;
    %jmp/0xz  T_4.11, 6;
    %vpi_call 2 29 "$display", "FAIL rollover: expected 0 got %0d", v0x555555a15d90_0 {0 0 0};
    %load/vec4 v0x555555a15e30_0;
    %addi 1, 0, 32;
    %store/vec4 v0x555555a15e30_0, 0, 32;
    %jmp T_4.12;
T_4.11 ;
    %vpi_call 2 31 "$display", "PASS rollover" {0 0 0};
T_4.12 ;
    %jmp T_4.10;
T_4.9 ;
    %load/vec4 v0x555555a15ed0_0;
    %addi 1, 0, 32;
    %vpi_call 2 33 "$display", "FAIL count step %0d: expected %0d got %0d", v0x555555a15ed0_0, S<0,vec4,s32>, v0x555555a15d90_0 {1 0 0};
    %load/vec4 v0x555555a15e30_0;
    %addi 1, 0, 32;
    %store/vec4 v0x555555a15e30_0, 0, 32;
T_4.10 ;
    %jmp T_4.6;
T_4.5 ;
    %load/vec4 v0x555555a15ed0_0;
    %cmpi/ne 15, 0, 32;
    %jmp/0xz  T_4.13, 4;
    %vpi_call 2 37 "$display", "PASS count=%0d", v0x555555a15d90_0 {0 0 0};
T_4.13 ;
T_4.6 ;
T_4.4 ; for-loop step statement
    %load/vec4 v0x555555a15ed0_0;
    %addi 1, 0, 32;
    %store/vec4 v0x555555a15ed0_0, 0, 32;
    %jmp T_4.2;
T_4.3 ; for-loop exit label
    %wait E_0x5555559c0890;
    %delay 1, 0;
    %wait E_0x5555559c0890;
    %delay 1, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x555555a15fb0_0, 0, 1;
    %wait E_0x5555559c0890;
    %delay 1, 0;
    %load/vec4 v0x555555a15d90_0;
    %cmpi/ne 0, 0, 4;
    %jmp/0xz  T_4.15, 6;
    %vpi_call 2 47 "$display", "FAIL mid-reset: got %0d", v0x555555a15d90_0 {0 0 0};
    %load/vec4 v0x555555a15e30_0;
    %addi 1, 0, 32;
    %store/vec4 v0x555555a15e30_0, 0, 32;
    %jmp T_4.16;
T_4.15 ;
    %vpi_call 2 49 "$display", "PASS mid-reset" {0 0 0};
T_4.16 ;
    %load/vec4 v0x555555a15e30_0;
    %cmpi/e 0, 0, 32;
    %jmp/0xz  T_4.17, 4;
    %vpi_call 2 51 "$display", "ALL TESTS PASSED" {0 0 0};
    %jmp T_4.18;
T_4.17 ;
    %vpi_call 2 52 "$display", "%0d TEST(S) FAILED", v0x555555a15e30_0 {0 0 0};
T_4.18 ;
    %vpi_call 2 53 "$finish" {0 0 0};
    %end;
    .thread T_4;
